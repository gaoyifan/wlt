<!doctype html>
<html lang="zh-CN">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>网络通</title>
    <style>
        :root {
            --primary: #3157d5;
            --primary-hover: #2748b8;
            --primary-soft: #eef2ff;
            --danger: #d94b68;
            --danger-hover: #bd3d57;
            --success: #16a085;
            --text: #20263a;
            --text-light: #737b91;
            --bg: #f3f5f9;
            --card-bg: #ffffff;
            --border: #dde2ec;
            --shadow: 0 12px 32px rgba(31, 42, 68, 0.08);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            line-height: 1.6;
            color: var(--text);
            background: linear-gradient(180deg, #e9eeff 0, var(--bg) 240px);
            padding: 0;
            margin: 0;
        }

        .container {
            max-width: 620px;
            margin: 0 auto;
            padding: 24px 20px 40px;
        }

        header {
            background: linear-gradient(135deg, #2948b8, #496de0);
            color: white;
            padding: 24px 0;
            text-align: center;
            box-shadow: 0 8px 24px rgba(49, 87, 213, 0.22);
        }

        header h1 {
            margin: 0;
            font-size: 1.7rem;
            letter-spacing: 0.08em;
        }

        .card {
            background: var(--card-bg);
            border: 1px solid rgba(221, 226, 236, 0.8);
            border-radius: 14px;
            box-shadow: var(--shadow);
            padding: 22px;
            margin-bottom: 20px;
        }

        .info-row {
            display: flex;
            align-items: center;
            margin-bottom: 10px;
        }

        .info-label {
            font-weight: 600;
            width: 100px;
            color: var(--text-light);
        }

        .info-value {
            font-weight: 500;
        }

        .info-value.highlight {
            color: var(--primary);
        }

        h2 {
            font-size: 1.05rem;
            margin: 0 0 12px;
            color: var(--text);
        }

        .option-group {
            margin-bottom: 22px;
        }

        .outlet-picker {
            border: 1px solid var(--border);
            border-radius: 10px;
            background: #fff;
            overflow: hidden;
            transition: border-color 0.18s, box-shadow 0.18s;
        }

        .outlet-picker.is-open {
            border-color: var(--primary);
            box-shadow: 0 0 0 3px rgba(49, 87, 213, 0.12);
        }

        .picker-toggle {
            width: 100%;
            min-height: 50px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            padding: 12px 15px;
            color: var(--text);
            background: var(--primary-soft);
            border: 0;
            font: inherit;
            font-size: 0.92rem;
            font-weight: 550;
            text-align: left;
            cursor: pointer;
        }

        .picker-value {
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .picker-chevron {
            width: 7px;
            height: 7px;
            flex: 0 0 auto;
            margin-right: 2px;
            border-right: 1.5px solid var(--primary);
            border-bottom: 1.5px solid var(--primary);
            transform: rotate(45deg) translateY(-1px);
            transition: transform 0.18s ease;
        }

        .outlet-picker.is-open .picker-chevron {
            transform: rotate(225deg) translate(-1px, -1px);
        }

        .picker-options {
            border-top: 1px solid var(--border);
        }

        .outlet-picker.enhanced:not(.is-open) .picker-options {
            display: none;
        }

        .outlet-option {
            position: relative;
            border-bottom: 1px solid var(--border);
        }

        .outlet-option:last-child {
            border-bottom: 0;
        }

        .outlet-option input[type="radio"],
        .time-item input[type="radio"] {
            position: absolute;
            opacity: 0;
            pointer-events: none;
        }

        .outlet-option label {
            min-height: 46px;
            display: flex;
            align-items: center;
            padding: 10px 15px;
            font-size: 0.9rem;
            background: #fff;
            cursor: pointer;
            transition: color 0.15s, background-color 0.15s;
        }

        .outlet-option label:hover {
            color: var(--primary);
            background: #f7f9ff;
        }

        .outlet-option input[type="radio"]:checked+label {
            color: var(--primary);
            font-weight: 600;
            background: var(--primary-soft);
        }

        .time-options {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .time-item {
            position: relative;
        }

        .time-item label {
            display: block;
            min-width: 74px;
            padding: 9px 14px;
            text-align: center;
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 9px;
            cursor: pointer;
            transition: all 0.15s;
        }

        .time-item input[type="radio"]:checked+label {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
            box-shadow: 0 4px 12px rgba(49, 87, 213, 0.2);
        }

        .btn {
            display: inline-block;
            font-weight: 500;
            text-align: center;
            white-space: nowrap;
            vertical-align: middle;
            user-select: none;
            border: 1px solid transparent;
            padding: 10px 20px;
            font-size: 1rem;
            line-height: 1.5;
            border-radius: 9px;
            transition: all 0.15s ease-in-out;
            cursor: pointer;
            margin-top: 15px;
            width: 100%;
        }

        .btn-primary {
            color: #fff;
            background-color: var(--primary);
            border-color: var(--primary);
        }

        .btn-primary:hover {
            background-color: var(--primary-hover);
            border-color: var(--primary-hover);
        }

        .btn-danger {
            color: #fff;
            background-color: var(--danger);
            border-color: var(--danger);
        }

        .btn-danger:hover {
            background-color: var(--danger-hover);
            border-color: var(--danger-hover);
        }

        .flash-message {
            padding: 12px 14px;
            background-color: rgba(6, 214, 160, 0.1);
            border-left: 4px solid var(--success);
            color: #2b2d42;
            margin-bottom: 20px;
            border-radius: 9px;
            font-weight: 500;
        }

        .actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
        }

        .actions .btn {
            margin-top: 15px;
        }

        @media (max-width: 480px) {
            .container {
                padding: 18px 14px 32px;
            }

            .card {
                padding: 18px;
            }

            .info-label {
                width: 86px;
            }

            .time-item {
                flex: 1 1 calc(33.333% - 8px);
            }

            .time-item label {
                min-width: 0;
            }
        }
    </style>
</head>

<body>
    <header>
        <h1>网络通</h1>
    </header>

    <div class="container">
        {% with messages = get_flashed_messages() %}
        {% if messages %}
        <div class="flash-message">{{ messages[0] }}</div>
        {% endif %}
        {% endwith %}

        <div class="card">
            <h2>当前信息</h2>
            <div class="info-row">
                <div class="info-label">IP 地址</div>
                <div class="info-value">{{ ip }}</div>
            </div>
            <div class="info-row">
                <div class="info-label">主机名</div>
                <div class="info-value">{{ hostname }}</div>
            </div>
            <div class="info-row">
                <div class="info-label">当前出口</div>
                <div class="info-value highlight">{{ current_outlet }}</div>
            </div>
            <div class="info-row">
                <div class="info-label">剩余时间</div>
                <div class="info-value" id="remaining-time">{{ expires_seconds and (expires_seconds | string + '秒') or
                    '永久' }}</div>
            </div>
        </div>

        <div class="card">
            <form id="open-net-form" method="post" action="{{ url_for('open_net') }}">
                {% for group in outlet_groups %}
                <div class="option-group">
                    <h2>{{ group.title }}</h2>
                    <div class="outlet-picker">
                        <button class="picker-toggle" type="button" aria-expanded="false">
                            <span class="picker-value">{{ group.selected }}</span>
                            <span class="picker-chevron" aria-hidden="true"></span>
                        </button>
                        <div class="picker-options">
                            {% for o in group.options %}
                            <div class="outlet-option">
                                <input type="radio" name="{{ group.field }}" id="{{ group.field }}-{{ loop.index }}"
                                    value="{{ o }}" {% if o==group.selected %}checked{% endif %}>
                                <label for="{{ group.field }}-{{ loop.index }}">{{ o }}</label>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                </div>
                {% endfor %}

                <div class="option-group">
                    <h2>选择时限</h2>
                    <div class="time-options">
                        {% for label, hour in time_limits %}
                        <div class="time-item">
                            <input type="radio" name="hours" id="hours-{{ loop.index }}" value="{{ hour }}" {% if
                                loop.first %}checked{% endif %}>
                            <label for="hours-{{ loop.index }}">{{ label }}</label>
                        </div>
                        {% endfor %}
                    </div>
                </div>

            </form>

            <div class="actions">
                <button type="submit" form="open-net-form" class="btn btn-primary">开通网络</button>
                <form method="post" action="{{ url_for('close_net') }}">
                    <button type="submit" class="btn btn-danger">重置网络</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.outlet-picker').forEach((picker) => {
            const toggle = picker.querySelector('.picker-toggle');
            const value = picker.querySelector('.picker-value');
            const radios = picker.querySelectorAll('input[type="radio"]');

            const setOpen = (open) => {
                picker.classList.toggle('is-open', open);
                toggle.setAttribute('aria-expanded', String(open));
            };

            picker.classList.add('enhanced');
            toggle.addEventListener('click', () => {
                const opening = !picker.classList.contains('is-open');
                document.querySelectorAll('.outlet-picker.is-open').forEach((other) => {
                    if (other !== picker) {
                        other.classList.remove('is-open');
                        other.querySelector('.picker-toggle').setAttribute('aria-expanded', 'false');
                    }
                });
                setOpen(opening);
            });

            radios.forEach((radio) => {
                radio.addEventListener('change', () => {
                    if (radio.checked) {
                        value.textContent = radio.value;
                        setOpen(false);
                    }
                });
            });
        });

        document.addEventListener('click', (event) => {
            if (!event.target.closest('.outlet-picker')) {
                document.querySelectorAll('.outlet-picker.is-open').forEach((picker) => {
                    picker.classList.remove('is-open');
                    picker.querySelector('.picker-toggle').setAttribute('aria-expanded', 'false');
                });
            }
        });

        document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') {
                document.querySelectorAll('.outlet-picker.is-open').forEach((picker) => {
                    picker.classList.remove('is-open');
                    picker.querySelector('.picker-toggle').setAttribute('aria-expanded', 'false');
                    picker.querySelector('.picker-toggle').focus();
                });
            }
        });

        // 初始化剩余时间（秒）
        let remainingSeconds = {{ expires_seconds or 'null' }};


        function formatTime(seconds) {
            if (seconds === null || seconds === undefined) {
                return '永久';
            }

            if (seconds <= 0) {
                return '已过期';
            }

            const hours = Math.floor(seconds / 3600);
            const minutes = Math.floor((seconds % 3600) / 60);
            const secs = seconds % 60;

            if (hours > 0) {
                return `${hours}小时${minutes}分钟${secs}秒`;
            } else if (minutes > 0) {
                return `${minutes}分钟${secs}秒`;
            } else {
                return `${secs}秒`;
            }
        }

        function updateRemainingTime() {
            const timeElement = document.getElementById('remaining-time');

            if (remainingSeconds === null) {
                timeElement.textContent = '永久';
                return;
            }

            if (remainingSeconds <= 0) {
                timeElement.textContent = '已过期';
                timeElement.style.color = '#ef476f'; // 红色显示过期
                return;
            }

            timeElement.textContent = formatTime(remainingSeconds);
            remainingSeconds--;
        }

        // 页面加载时立即更新一次
        updateRemainingTime();

        // 每秒更新一次（仅在有时限时）
        if (remainingSeconds !== null) {
            setInterval(updateRemainingTime, 1000);
        }
    </script>
</body>

</html>
